{
  "type": "flex",
  "altText": "Order receipt",
  "contents": {
    "type": "bubble",
    "body": {
      "type": "box",
      "layout": "vertical",
      "contents": [
        { "type": "text", "text": "RECEIPT", "weight": "bold", "color": "#1DB446", "size": "sm" },
        { "type": "text", "text": "Order #12345", "weight": "bold", "size": "xxl", "margin": "md" },
        { "type": "text", "text": "January 15, 2024", "size": "xs", "color": "#aaaaaa" },
        { "type": "separator", "margin": "xxl" },
        {
          "type": "box", "layout": "vertical", "margin": "xxl", "spacing": "sm",
          "contents": [
            {
              "type": "box", "layout": "horizontal",
              "contents": [
                { "type": "text", "text": "Product A", "size": "sm", "color": "#555555", "flex": 0 },
                { "type": "text", "text": "NT$500", "size": "sm", "color": "#111111", "align": "end" }
              ]
            },
            {
              "type": "box", "layout": "horizontal",
              "contents": [
                { "type": "text", "text": "Product B × 2", "size": "sm", "color": "#555555", "flex": 0 },
                { "type": "text", "text": "NT$400", "size": "sm", "color": "#111111", "align": "end" }
              ]
            },
            { "type": "separator", "margin": "xxl" },
            {
              "type": "box", "layout": "horizontal", "margin": "xxl",
              "contents": [
                { "type": "text", "text": "TOTAL", "size": "sm", "color": "#555555" },
                { "type": "text", "text": "NT$900", "size": "sm", "color": "#111111", "align": "end", "weight": "bold" }
              ]
            }
          ]
        }
      ]
    },
    "footer": {
      "type": "box",
      "layout": "vertical",
      "contents": [{
        "type": "button", "style": "primary",
        "action": { "type": "uri", "label": "View Order", "uri": "https://example.com/order/12345" }
      }]
    }
  }
}
